# Environment Variables
AGENDOR_API_KEY=your_token_here
AGENDOR_API_BASE_URL=https://api.agendor.com.br/v3
AGENDOR_RATE_LIMIT_RPS=4

# MongoDB
MONGODB_URI=your_connection_string_here
